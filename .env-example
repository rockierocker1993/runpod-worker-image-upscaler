# S3
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_KEY_PREFIX=upscaled/
S3_ENDPOINT_URL=
DELETE_INPUT_AFTER_UPSCALE=false
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Database
ENABLE_DATABASE=false
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# Models
MODEL_2X_PATH=/models/RealESRGAN_x2plus.pth
MODEL_4X_PATH=/models/RealESRGAN_x4plus.pth

WEBHOOK_CALLBACK_URL=https://your-domain.com/webhook
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_AUTH_TOKEN=your-secret-token

DELETE_INPUT_AFTER_UPSCALE=false